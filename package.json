{
  "name": "aetherenroll",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
  "seed": "node --env-file=.env scripts/seed.js",
  "images:gen": "node --env-file=.env scripts/generate-product-images.js",
  "index:products": "node --env-file=.env scripts/index-products.js",
  "qdrant:check": "node -e \"(async()=>{const{QdrantClient}=require('@qdrant/js-client-rest');const c=new QdrantClient({url:process.env.QDRANT_URL||'http://localhost:6333',apiKey:process.env.QDRANT_API_KEY,checkCompatibility:false});const col=process.env.QDRANT_COLLECTION||'products';try{await c.getCollection(col);console.log('Collection OK:',col);}catch(e){console.error('Qdrant not reachable or missing collection',e.message);process.exit(1);} })()\"",
  "qdrant:setup": "node --env-file=.env scripts/qdrant-setup.js",
  "qdrant:reset": "node --env-file=.env scripts/qdrant-reset.js",
  "brochures:gen": "node --env-file=.env scripts/generate-brochures.js"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.9.1",
    "@langchain/openai": "^0.3.7",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.1",
  "groq-sdk": "^0.7.0",
    "mongoose": "^8.6.1",
    "next": "^14.2.7",
    "next-themes": "^0.3.0",
  "@qdrant/js-client-rest": "^1.15.1",
  "fastembed": "^1.14.4",
  "ioredis": "^5.4.1",
    "pdfkit": "^0.15.0",
    "react": "^18.3.1",
  "react-dom": "^18.3.1",
  "react-hook-form": "^7.53.0",
  "@reduxjs/toolkit": "^2.2.7",
  "react-redux": "^9.1.2",
  "@hookform/resolvers": "^3.9.0",
  "svix": "^1.73.0",
  "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.73",
    "@types/react-dom": "^18.2.23",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.7",
    "postcss": "^8.4.38",
  "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4"
  }
}
