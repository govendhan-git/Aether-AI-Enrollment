# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

## Mongo
# Prefer DATABASE_URL if present, else MONGODB_URI
DATABASE_URL=
MONGODB_URI=

## AI Models
# Provider selection (groq | openai | ollama)
AI_PROVIDER=groq
# Groq (preferred if key present)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
# Optional per-task overrides
# GROQ_MODEL_CHAT=llama-3.1-8b-instant
# GROQ_MODEL_RAG=llama-3.3-70b-versatile
# GROQ_MODEL_JSON=llama-3.1-8b-instant

# App
NEXT_PUBLIC_APP_NAME=Enrollment App
ENCRYPTION_SECRET=

## Vector Search (optional)
# Set QDRANT_URL to enable vector search; otherwise the app falls back to lexical search.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=products
# Indexer embeddings provider: 'fastembed' (if installed) or 'xenova'
EMBEDDINGS_PROVIDER=xenova
